# Supabase — populate from `supabase status` for local, or project settings for hosted
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — transactional email provider
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@rootedrightfarms.com
CONTACT_NOTIFICATION_TO=
# Resend Audiences (newsletter)
RESEND_AUDIENCE_ID=

# Admin access is granted via the public.user_roles table in Supabase.
# To promote a user: select public.grant_role_by_email('email@example.com', 'admin');
# Emails in the handle_new_user trigger allowlist (migration 20260414000009)
# are auto-promoted on signup.

# Employment form PII encryption (AES-256-GCM key, 16+ chars)
PII_ENCRYPTION_KEY=

# Instagram Graph API (VA-29)
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
